# ---------------------------------------------------------------------------
# LLM provider configuration
# ---------------------------------------------------------------------------
# The app is provider-agnostic. Pick a provider and set its model + API key.
#
# LLM_PROVIDER options:
#   anthropic          Claude, via Anthropic's API (default)
#   openrouter         Any model on OpenRouter
#   deepseek           DeepSeek API (text-only)
#   moonshot           Moonshot / Kimi API (text-only by default)
#   openai-compatible  Any other OpenAI-compatible endpoint (requires LLM_BASE_URL)

LLM_PROVIDER=anthropic

# Model id for the chosen provider. If omitted, a sensible default is used.
#   anthropic         -> claude-sonnet-4-5
#   openrouter        -> e.g. anthropic/claude-sonnet-4.5, deepseek/deepseek-chat
#   deepseek          -> deepseek-chat
#   moonshot          -> moonshot-v1-8k  (or kimi-* models)
# LLM_MODEL=claude-sonnet-4-5

# Optional friendly label shown in the "Generated by ..." note under the output.
# Falls back to LLM_MODEL when unset. e.g. "Sonnet 4.5", "DeepSeek V3".
# LLM_MODEL_LABEL=

# API key for the chosen provider.
# For LLM_PROVIDER=anthropic this falls back to ANTHROPIC_API_KEY if unset.
LLM_API_KEY=

# Base URL. Auto-filled for known providers; REQUIRED for openai-compatible.
#   openrouter -> https://openrouter.ai/api/v1
#   deepseek   -> https://api.deepseek.com/v1
#   moonshot   -> https://api.moonshot.cn/v1
# LLM_BASE_URL=

# Whether the chosen model can analyze uploaded images. Defaults are inferred
# per provider (anthropic/openrouter: true; deepseek/moonshot: false). Override
# when you select a vision-capable model on a normally text-only provider.
# LLM_SUPPORTS_VISION=true

# Backward-compatible Anthropic key (used when LLM_PROVIDER=anthropic and
# LLM_API_KEY is not set).
ANTHROPIC_API_KEY=
